{% extends 'base.html.twig' %}

{% block title %}Consumer{% endblock %}

{% block body %}
    <h1>Consumer</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ consumer.id }}</td>
            </tr>
            <tr>
                <th>First_name</th>
                <td>{{ consumer.firstName }}</td>
            </tr>
            <tr>
                <th>Last_name</th>
                <td>{{ consumer.lastName }}</td>
            </tr>
            <tr>
                <th>Phone_number</th>
                <td>{{ consumer.phoneNumber }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_consumer_index') }}">back to list</a>

    <a href="{{ path('app_consumer_edit', {'id': consumer.id}) }}">edit</a>

    {% if is_granted('ROLE_ADMIN') %}
        {{ include('consumer/_delete_form.html.twig') }}
    {% endif %}
{% endblock %}
