{% extends 'base.html.twig' %}

{% block title %}Business{% endblock %}

{% block body %}
    <h1>Business</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ business.id }}</td>
            </tr>
            <tr>
                <th>Name</th>
                <td>{{ business.name }}</td>
            </tr>
            <tr>
                <th>City</th>
                <td>{{ business.city }}</td>
            </tr>
            <tr>
                <th>Street</th>
                <td>{{ business.street }}</td>
            </tr>
            <tr>
                <th>House_number</th>
                <td>{{ business.houseNumber }}</td>
            </tr>
            <tr>
                <th>Phone_number</th>
                <td>{{ business.phoneNumber }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_business_index') }}">back to list</a>

    <a href="{{ path('app_business_edit', {'id': business.id}) }}">edit</a>

    {{ include('business/_delete_form.html.twig') }}
{% endblock %}
